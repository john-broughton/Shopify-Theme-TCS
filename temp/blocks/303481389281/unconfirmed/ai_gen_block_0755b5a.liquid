{% doc %}
  @prompt
    A section with a headline, subheading and 5 column vertical layout where i will have a headline and paragraph to support the content
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-five-column-section-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-five-column-section__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-five-column-section__headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.headline_size }}px;
    color: {{ block.settings.headline_color }};
    margin: 0 0 {{ block.settings.subheading_spacing }}px 0;
    line-height: 1.2;
  }

  .ai-five-column-section__subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 0;
    line-height: 1.4;
  }

  .ai-five-column-section__columns-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: {{ block.settings.column_gap }}px;
  }

  .ai-five-column-section__column-{{ ai_gen_id }} {
    text-align: {{ block.settings.column_text_alignment }};
  }

  .ai-five-column-section__column-headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.column_headline_size }}px;
    color: {{ block.settings.column_headline_color }};
    margin: 0 0 {{ block.settings.column_content_spacing }}px 0;
    line-height: 1.3;
  }

  .ai-five-column-section__column-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.column_text_size }}px;
    color: {{ block.settings.column_text_color }};
    margin: 0;
    line-height: 1.5;
  }

  @media screen and (max-width: 989px) {
    .ai-five-column-section__columns-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-five-column-section__columns-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-five-column-section__headline-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.headline_size }}px * 0.8);
    }

    .ai-five-column-section__subheading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subheading_size }}px * 0.9);
    }
  }
{% endstyle %}

<div class="ai-five-column-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-five-column-section__header-{{ ai_gen_id }}">
    {% if block.settings.headline != blank %}
      <h2 class="ai-five-column-section__headline-{{ ai_gen_id }}">
        {{ block.settings.headline }}
      </h2>
    {% endif %}

    {% if block.settings.subheading != blank %}
      <div class="ai-five-column-section__subheading-{{ ai_gen_id }}">
        {{ block.settings.subheading }}
      </div>
    {% endif %}
  </div>

  <div class="ai-five-column-section__columns-{{ ai_gen_id }}">
    {% for i in (1..5) %}
      {% assign column_headline_key = 'column_' | append: i | append: '_headline' %}
      {% assign column_text_key = 'column_' | append: i | append: '_text' %}
      
      <div class="ai-five-column-section__column-{{ ai_gen_id }}">
        {% if block.settings[column_headline_key] != blank %}
          <h3 class="ai-five-column-section__column-headline-{{ ai_gen_id }}">
            {{ block.settings[column_headline_key] }}
          </h3>
        {% endif %}

        {% if block.settings[column_text_key] != blank %}
          <div class="ai-five-column-section__column-text-{{ ai_gen_id }}">
            {{ block.settings[column_text_key] }}
          </div>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</div>

