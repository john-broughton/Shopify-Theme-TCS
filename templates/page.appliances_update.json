      "blocks": {
        "ai_gen_block_578df23_Fih9wq": {
          "type": "ai_gen_block_578df23",
          "settings": {
            "headline": "How we shop for appliances - with you, not at you.",
            "subheading": "You probably aren't going to buy a 48-inch range twice. So we don't sell them like impulse purchases. Here's how it works when you bring a project to The Cook's Station.",
            "text_alignment": "center",
            "headline_size": 36,
            "subheading_size": 16,
            "headline_color": "#000000",
            "subheading_color": "#484848",
            "column_1_headline": "Visit",
            "column_1_text": "<p>Come see us and experience the showroom. Touch the knobs, listen to the hood, ask the questions. Our team is here six days a week.</p>",
            "column_2_headline": "Consult",
            "column_2_text": "<p>We start with how you cook, not what you should buy. Layout, timeline, budget, who's in the kitchen.</p>",
            "column_3_headline": "Configure & Quote",
            "column_3_text": "<p>We spec the right sizes, finishes, fuel types, and accessories -  and we'll tell you when a less expensive option will serve you better.</p>",
            "column_4_headline": "Order & Schedule",
            "column_4_text": "<p>We coordinate across 20+ brands and keep you posted on lead times so your timeline holds.</p>",
            "column_5_headline": "Install & Support",
            "column_5_text": "<p>Delivery, authorized service, warranty registration, and a real human to call when something blinks the wrong color in three years.</p>",
            "column_text_alignment": "center",
            "column_headline_size": 18,
            "column_text_size": 14,
            "column_headline_color": "#000000",
            "column_text_color": "#484848",
